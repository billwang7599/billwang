# Nerd Font so Starship prompt + eza icons render (no tofu boxes □).
# Installed via `brew install --cask font-meslo-lg-nerd-font` (see startup.sh).
font-family = "MesloLGS Nerd Font"
font-size = 13
font-thicken = true

# Glassy appearance
background = 1a1a1a
background-opacity = 0.75
background-blur-radius = 20

# macOS-specific: transparent titlebar for full glass effect
macos-titlebar-style = transparent
macos-window-shadow = true

# Padding so text doesn't hug the edges
window-padding-x = 12
window-padding-y = 12
window-padding-balance = true

# Optional: remove window chrome for a floating glass panel look
# window-decoration = none

# Optional: slightly rounded corners (macOS)
window-step-resize = false
